{
  "name": "urdu-english-interpreter",
  "version": "0.1.0",
  "description": "Real-Time Urdu to English Voice Interpreter - Phase 1 (Translation Subtitles MVP)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.jsx --bundle --outfile=dist/bundle.js --loader:.jsx=jsx",
    "watch": "esbuild src/index.jsx --bundle --outfile=dist/bundle.js --loader:.jsx=jsx --watch",
    "start": "npm run build && electron ."
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "esbuild": "^0.21.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}

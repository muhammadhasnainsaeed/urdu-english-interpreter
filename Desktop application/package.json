{
  "name": "desktop-application",
  "version": "1.0.0",
  "description": "Desktop application for English-Urdu translation",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE ELECTRON_DEV=true electron .\"",
    "build": "vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron ."
  },
  "keywords": [],
  "author": "muhammadhasnainsaeed",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.6",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
